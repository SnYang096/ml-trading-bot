      "id": 22,
      "gridPos": {
        "h": 2,
        "w": 24,
        "x": 0,
        "y": 23
      },
      "options": {
        "mode": "markdown",
        "content": "**对账频率**：Trend/Hedge REST backfill **60s**；Spot pending 检查 **~5s**，指标上报 **30s**。`reconciliation_ok=0` 或 issue>0 → **需人工检查** DB 与币安挂单（Trend 含 algo STOP）。告警见 Prometheus `Quant*ReconciliationManualCheck`。"
      },
      "transparent": true
    },
    {
      "type": "stat",
      "title": "Trend · 对账状态",
      "id": 23,
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 0,
        "y": 25
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-monitoring"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "min(mlbot_reconciliation_ok{job=\"quant-trend-fattail\",scope=\"trend\"})",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 1,
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "需人工检查",
                  "color": "red",
                  "index": 0
                },
                "1": {
                  "text": "正常",
                  "color": "green",
                  "index": 1
                }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
