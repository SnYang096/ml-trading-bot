      "datasource": { "type": "prometheus", "uid": "prometheus-monitoring" },
      "targets": [
        {
          "refId": "A",
          "expr": "mlbot_strategy_feature_value{job=~\"$trend_job\",strategy=~\"$trend_strategy\",symbol=~\"$trend_symbol\",timeframe=~\"$trend_timeframe\",layer=~\"$trend_feature_layer\"}",
