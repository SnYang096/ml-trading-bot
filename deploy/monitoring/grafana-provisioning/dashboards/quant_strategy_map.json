      "targets": [
        { "refId": "A", "expr": "sum by (strategy) (rate(mlbot_orders_total{job=~\"$trend_job\",strategy=~\"$trend_strategy\"}[$__rate_interval]))", "legendFormat": "orders {{strategy}}" },
        { "refId": "B", "expr": "sum by (strategy) (rate(mlbot_signals_total{job=~\"$trend_job\",strategy=~\"$trend_strategy\"}[$__rate_interval]))", "legendFormat": "signals {{strategy}}" }
