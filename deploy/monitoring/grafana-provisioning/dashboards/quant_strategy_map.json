    {
      "type": "timeseries",
      "title": "Trend · OHLC",
      "id": 301,
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus-monitoring" },
      "targets": [
        { "refId": "A", "expr": "mlbot_strategy_symbol_bar_ohlc{job=~\"$trend_job\",strategy=~\"$trend_strategy\",symbol=~\"$trend_symbol\",timeframe=~\"$trend_timeframe\",field=\"open\"}", "legendFormat": "open" },
        { "refId": "B", "expr": "mlbot_strategy_symbol_bar_ohlc{job=~\"$trend_job\",strategy=~\"$trend_strategy\",symbol=~\"$trend_symbol\",timeframe=~\"$trend_timeframe\",field=\"high\"}", "legendFormat": "high" },
        { "refId": "C", "expr": "mlbot_strategy_symbol_bar_ohlc{job=~\"$trend_job\",strategy=~\"$trend_strategy\",symbol=~\"$trend_symbol\",timeframe=~\"$trend_timeframe\",field=\"low\"}", "legendFormat": "low" },
        { "refId": "D", "expr": "mlbot_strategy_symbol_bar_ohlc{job=~\"$trend_job\",strategy=~\"$trend_strategy\",symbol=~\"$trend_symbol\",timeframe=~\"$trend_timeframe\",field=\"close\"}", "legendFormat": "close" }
      ],
      "fieldConfig": { "defaults": { "unit": "none" }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } }
    },
    {
      "type": "timeseries",
      "title": "Trend · funnel (rate by stage × strategy)",
      "id": 302,
      "gridPos": { "h": 8, "w": 14, "x": 0, "y": 10 },
      "datasource": { "type": "prometheus", "uid": "prometheus-monitoring" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (strategy, stage) (rate(mlbot_funnel_total{job=~\"$trend_job\",strategy=~\"$trend_strategy\"}[$__rate_interval]))",
          "legendFormat": "{{strategy}} · {{stage}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "stacking": { "mode": "normal", "group": "A" } },
          "unit": "ops"
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } }
    },
    {
      "type": "timeseries",
      "title": "Trend · orders & signals (rate)",
      "id": 303,
      "gridPos": { "h": 8, "w": 10, "x": 14, "y": 10 },
