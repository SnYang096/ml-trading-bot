  "panels": [
    {
      "type": "text",
      "title": "",
      "id": 891,
      "gridPos": { "h": 3, "w": 24, "x": 0, "y": 0 },
      "options": {
        "mode": "markdown",
        "content": "**Multi-leg hedge only** — separate dashboard from Trend. Pipeline panel uses `mlbot_multi_leg_*`. OHLC/feature gauges appear when `run_multi_leg_live` publishes them. Symbol multi-select uses `${symbol:regex}`."
      },
      "transparent": false
    },
    {
      "type": "stat",
      "title": "Hedge · OHLC series count",
      "id": 890,
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 3 },
      "datasource": { "type": "prometheus", "uid": "prometheus-monitoring" },
      "targets": [
        {
          "refId": "A",
          "expr": "count(mlbot_strategy_symbol_bar_ohlc{job=~\"$job\",strategy=~\"${strategy:regex}\",symbol=~\"${symbol:regex}\",timeframe=~\"${timeframe:regex}\"})",
          "legendFormat": "series"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "none" }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "values": false }, "colorMode": "value", "graphMode": "none" }
    },
    {
      "type": "stat",
      "title": "Hedge · multi-leg bars rate (sum)",
      "id": 893,
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 3 },
      "datasource": { "type": "prometheus", "uid": "prometheus-monitoring" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(mlbot_multi_leg_bars_processed_total{job=~\"$job\",strategy=~\"${strategy:regex}\",symbol=~\"${symbol:regex}\"}[$__rate_interval]))",
          "legendFormat": "ops"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "values": false }, "colorMode": "value", "graphMode": "area" }
    },
    {
      "type": "timeseries",
      "title": "Hedge · OHLC",
      "id": 311,
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus-monitoring" },
      "targets": [
        { "refId": "A", "expr": "mlbot_strategy_symbol_bar_ohlc{job=~\"$job\",strategy=~\"${strategy:regex}\",symbol=~\"${symbol:regex}\",timeframe=~\"${timeframe:regex}\",field=\"open\"}", "legendFormat": "open" },
        { "refId": "B", "expr": "mlbot_strategy_symbol_bar_ohlc{job=~\"$job\",strategy=~\"${strategy:regex}\",symbol=~\"${symbol:regex}\",timeframe=~\"${timeframe:regex}\",field=\"high\"}", "legendFormat": "high" },
        { "refId": "C", "expr": "mlbot_strategy_symbol_bar_ohlc{job=~\"$job\",strategy=~\"${strategy:regex}\",symbol=~\"${symbol:regex}\",timeframe=~\"${timeframe:regex}\",field=\"low\"}", "legendFormat": "low" },
        { "refId": "D", "expr": "mlbot_strategy_symbol_bar_ohlc{job=~\"$job\",strategy=~\"${strategy:regex}\",symbol=~\"${symbol:regex}\",timeframe=~\"${timeframe:regex}\",field=\"close\"}", "legendFormat": "close" }
      ],
      "fieldConfig": { "defaults": { "unit": "none" }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } }
    },
    {
      "type": "timeseries",
      "title": "Hedge · multi-leg pipeline",
      "id": 312,
      "gridPos": { "h": 8, "w": 14, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus-monitoring" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (strategy, symbol) (rate(mlbot_multi_leg_bars_processed_total{job=~\"$job\",strategy=~\"${strategy:regex}\",symbol=~\"${symbol:regex}\"}[$__rate_interval]))",
          "legendFormat": "bars {{strategy}}/{{symbol}}"
        },
        {
          "refId": "B",
          "expr": "sum by (strategy, symbol) (rate(mlbot_multi_leg_actions_total{job=~\"$job\",strategy=~\"${strategy:regex}\",symbol=~\"${symbol:regex}\"}[$__rate_interval]))",
          "legendFormat": "actions {{strategy}}/{{symbol}}"
        },
        {
          "refId": "C",
          "expr": "sum by (strategy, symbol) (rate(mlbot_multi_leg_execution_results_total{job=~\"$job\",strategy=~\"${strategy:regex}\",symbol=~\"${symbol:regex}\"}[$__rate_interval]))",
          "legendFormat": "exec {{strategy}}/{{symbol}}"
        },
        {
          "refId": "D",
          "expr": "sum by (strategy, symbol) (rate(mlbot_multi_leg_risk_rejected_total{job=~\"$job\",strategy=~\"${strategy:regex}\",symbol=~\"${symbol:regex}\"}[$__rate_interval]))",
          "legendFormat": "risk_reject {{strategy}}/{{symbol}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "stacking": { "mode": "normal", "group": "B" } },
          "unit": "ops"
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } }
    },
    {
      "type": "timeseries",
      "title": "Hedge · classic funnel / orders (if present on scrape)",
      "id": 313,
      "gridPos": { "h": 8, "w": 10, "x": 14, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus-monitoring" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (strategy, stage) (rate(mlbot_funnel_total{job=~\"$job\",strategy=~\"${strategy:regex}\"}[$__rate_interval]))",
          "legendFormat": "{{strategy}} · {{stage}}"
        },
        {
          "refId": "B",
          "expr": "sum by (strategy) (rate(mlbot_orders_total{job=~\"$job\",strategy=~\"${strategy:regex}\"}[$__rate_interval]))",
          "legendFormat": "orders {{strategy}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops", "custom": { "stacking": { "mode": "normal", "group": "C" } } },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } }
    },
    {
      "type": "timeseries",
      "title": "Hedge · features",
      "id": 314,
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "prometheus-monitoring" },
      "targets": [
        {
          "refId": "A",
          "expr": "mlbot_strategy_feature_value{job=~\"$job\",strategy=~\"${strategy:regex}\",symbol=~\"${symbol:regex}\",timeframe=~\"${timeframe:regex}\",layer=~\"${feature_layer:regex}\"}",
          "legendFormat": "{{layer}} · {{feature}}"
        }
      ],
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } }
    },
    {
      "type": "timeseries",
      "title": "Hedge · events",
      "id": 315,
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 32 },
      "datasource": { "type": "prometheus", "uid": "prometheus-monitoring" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (strategy, event, side) (increase(mlbot_strategy_event_total{job=~\"$job\",scope=\"hedge\",strategy=~\"${strategy:regex}\",symbol=~\"${symbol:regex}\"}[$__rate_interval]))",
          "legendFormat": "{{strategy}} {{event}} {{side}}"
        }
      ],
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } }
    },
    {
      "type": "timeseries",
      "title": "Hedge · last event price",
      "id": 316,
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 32 },
      "datasource": { "type": "prometheus", "uid": "prometheus-monitoring" },
      "targets": [
        {
          "refId": "A",
          "expr": "mlbot_strategy_event_price{job=~\"$job\",scope=\"hedge\",strategy=~\"${strategy:regex}\",symbol=~\"${symbol:regex}\"}",
          "legendFormat": "{{strategy}} {{event}} {{side}}"
        }
      ],
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } }
    },
    {
      "type": "table",
      "title": "Hedge · positions",
      "id": 317,
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 39 },
      "datasource": { "type": "prometheus", "uid": "prometheus-monitoring" },
      "targets": [
        { "refId": "A", "expr": "max by (strategy, symbol, side) (mlbot_position_qty{job=~\"$job\",scope=\"hedge\",strategy=~\"${strategy:regex}\",symbol=~\"${symbol:regex}\"})", "format": "table", "instant": true },
        { "refId": "B", "expr": "max by (strategy, symbol, side) (mlbot_position_notional_usdt{job=~\"$job\",scope=\"hedge\",strategy=~\"${strategy:regex}\",symbol=~\"${symbol:regex}\"})", "format": "table", "instant": true }
      ],
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "options": { "showHeader": true }
    }
  ],
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["quant", "strategy", "hedge", "multi-leg"],
  "templating": {
    "list": [
      {
        "name": "job",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus-monitoring" },
        "query": "label_values(mlbot_cpu_percent{job=~\"quant-hedge-.+\"}, job)",
        "refresh": 1,
        "multi": false,
        "includeAll": false,
        "current": { "text": "quant-hedge-multileg", "value": "quant-hedge-multileg", "selected": true }
      },
      {
        "name": "strategy",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus-monitoring" },
        "query": "label_values(mlbot_dashboard_catalog{job=~\"$job\",role=\"strategy\"}, name)",
        "refresh": 1,
        "multi": true,
        "includeAll": true,
        "allValue": ".+",
        "current": { "text": "All", "value": "$__all", "selected": true }
      },
      {
        "name": "symbol",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus-monitoring" },
        "query": "label_values(mlbot_dashboard_catalog{job=~\"$job\",role=\"symbol\"}, name)",
        "refresh": 1,
        "multi": true,
        "includeAll": true,
        "allValue": ".+",
        "current": { "text": "All", "value": "$__all", "selected": true }
      },
      {
        "name": "timeframe",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus-monitoring" },
        "query": "label_values({__name__=~\"mlbot_strategy_symbol_bar_ohlc|mlbot_strategy_feature_value\",job=~\"$job\",strategy=~\"${strategy:regex}\",symbol=~\"${symbol:regex}\"}, timeframe)",
        "refresh": 1,
        "multi": true,
        "includeAll": true,
        "allValue": ".+",
        "current": { "text": "All", "value": "$__all", "selected": true }
      },
      {
        "name": "feature_layer",
        "label": "layer",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus-monitoring" },
        "query": "label_values(mlbot_strategy_feature_value{job=~\"$job\",strategy=~\"${strategy:regex}\",symbol=~\"${symbol:regex}\"}, layer)",
        "refresh": 1,
        "multi": true,
        "includeAll": true,
        "allValue": ".+",
        "current": { "text": "All", "value": "$__all", "selected": true }
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "utc",
  "title": "Strategy Map · Multi-leg Hedge",
  "uid": "quant-strategy-map-hedge",
  "version": 1
