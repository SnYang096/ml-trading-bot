[flake8]
# 选择要忽略的错误码。
# E501: 行太长
# W503: 在二元运算符前换行
# W291: 尾随空格
# W293: 空行包含空格
# F401: 导入但未使用
# F541: f-string 缺少占位符
# F841: 赋值但未使用的变量
# E226: 算术运算符周围缺少空格
# E402: 模块导入不在顶部
# E401: 一行多个导入
# E203: 冒号前有空格（Black 格式化后常见）
# E722: 裸 except
# E231: 逗号后缺少空格（在字符串内容中不应检查）
# F405: star import 可能未定义的变量（alpha101 等库中常见，无法自动修复）
# E741: 模糊变量名（如 'l', 'O', 'I'，在某些上下文中是合理的，如 alpha101 函数参数）
# E731: lambda 赋值（在某些情况下是合理的，black 不会自动转换）
# E202: 花括号前空格（在 f-string 中，black 不会修复字符串内容）
# W504: 二元运算符后换行（与 W503 相反，black 可能不会自动修复）
# F811: 重复定义（某些情况下是合理的，如 alpha101 中的重复函数定义）
# F403: star import 警告（alpha101 等库中使用 star import 是合理的）
# F824: global 声明未使用（某些情况下 global 声明是为了文档目的）
# F821: 未定义名称（在 f-string 中，flake8 可能无法正确识别作用域）
# E712: 与 False 比较（某些情况下 == False 是合理的）
ignore = E501, W503, W291, W293, F401, F541, F841, E226, E402, E401, E203, E722, E201, E225, E231, F405, E741, E731, E202, W504, F811, F403, F824, F821, E712
max-line-length = 200
