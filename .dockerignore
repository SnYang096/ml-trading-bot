# =============================================================
# .dockerignore — Docker 构建上下文排除
# 构建命令: docker build -f docker/Dockerfile.live -t quant-engine .
# 构建上下文: 仓库根目录
# =============================================================

# ---- 运行时数据（绝不打包进镜像） ----
live/*/data/
*.db
data/
results/
models/
feature_store/
!src/feature_store/
!src/feature_store/**
src/feature_store/__pycache__/

# ---- API 密钥 ----
.env
.env.*
live/binance_mainnet.env
live/binance_testnet.env
live/server.env
config/local/

# ---- 大文件 / 模型产物 ----
*.pkl
*.h5
*.ckpt
*.pt
*.pth
*.onnx
*.whl
*.deb

# ---- Git / CI ----
.git/
.github/
.gitignore

# ---- deploy/（Grafana 等，不打进交易镜像）----
deploy/

# ---- 实验文档 + 文档 ----
z实验_*/
docs/
reports/
examples/

# ---- Python 编译缓存 ----
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/

# ---- 虚拟环境 ----
venv/
.venv/
env/
ENV/

# ---- IDE / OS ----
.vscode/
.idea/
.qoder/
*.swp
*.swo
.DS_Store
Thumbs.db

# ---- 测试 / Jupyter ----
.pytest_cache/
.coverage
htmlcov/
.ipynb_checkpoints/
*.ipynb

# ---- Docker 文件本身 ----
docker-compose*.yml
Dockerfile
.dockerignore

# ---- 日志 ----
*.log

