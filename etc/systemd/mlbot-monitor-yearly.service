[Unit]
Description=mlbot monitor yearly drift archive
After=docker.service network-online.target
Requires=docker.service
OnFailure=mlbot-monitor-notify@%n.service

[Service]
Type=oneshot
ExecStart=/opt/quant-engine/deploy/systemd/mlbot-monitor-docker-run.sh yearly

[Install]
WantedBy=multi-user.target
